# Copia este archivo como ".env" en tu computadora para pruebas locales.
# En Vercel, estas mismas dos variables se configuran en:
# Project Settings → Environment Variables (NO se sube este archivo a GitHub).

# El dominio de tu tienda, tal cual, sin https:// (ejemplo: drmarialerivers.myshopify.com)
VITE_SHOPIFY_STORE_DOMAIN=drmarialerivers.myshopify.com

# Admin API access token — se genera en:
# Shopify Admin → Configuración → Apps y canales de venta → Desarrollar apps → (tu app) → Tokens de API
VITE_SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
