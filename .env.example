# Copia este archivo como ".env" en tu computadora para pruebas locales.
# En Vercel, estas mismas variables se configuran en:
# Project Settings → Environment Variables (NO se sube este archivo a GitHub).
#
# IMPORTANTE: ninguna de estas lleva el prefijo VITE_ — son solo para el servidor
# (la función en /api/set-inventory.js), nunca llegan al navegador.

# El dominio de tu tienda, tal cual, sin https:// (ejemplo: drmarialerivers.myshopify.com)
SHOPIFY_STORE_DOMAIN=drmarialerivers.myshopify.com

# Client ID y Client Secret de tu app — se generan en:
# Dev Dashboard (dev.shopify.com/dashboard) → tu app → Settings
# Con estas tres variables el servidor pide un token nuevo cada vez que lo necesita,
# no hace falta ningún paso extra de autorización en el navegador.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
